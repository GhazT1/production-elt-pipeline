# Netflix Analytics Pipeline — Environment Variables
# ===================================================
# Copy this to .env (never commit .env to git).
# In production, inject these via AWS SSM / ECS task definitions / GitHub Secrets.

# ── Pipeline ────────────────────────────────────────────────────
PIPELINE_ENV=dev                          # dev | staging | prod

# ── AWS ─────────────────────────────────────────────────────────
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-netflix-data-bucket
SNS_FAILURE_TOPIC_ARN=arn:aws:sns:us-east-1:ACCOUNT_ID:YourTopic

# ── SSM Parameter Store paths (values stored in SSM, not here) ──
SSM_SF_USERNAME_PATH=/netflix-pipeline/snowflake/username
SSM_SF_PASSWORD_PATH=/netflix-pipeline/snowflake/password
SSM_SF_ACCOUNT_PATH=/netflix-pipeline/snowflake/account

# ── Snowflake (non-secret config) ───────────────────────────────
SF_WAREHOUSE=COMPUTE_WH
SF_DATABASE=PROD
SF_RAW_SCHEMA=DBT_RAW
SF_ROLE=TRANSFORMER

# ── dbt ─────────────────────────────────────────────────────────
DBT_PROJECT_DIR=/home/airflow/dbt-code
DBT_PROFILES_DIR=/home/airflow/.dbt
DBT_VENV_BIN=/home/airflow/dbt-env/bin
DBT_READER_ROLE=ANALYST

# ── Slack ────────────────────────────────────────────────────────
# Stored in Airflow Connections UI (id: slack_default), not here.
# Set the webhook token as the connection password in Airflow.
SLACK_CONN_ID=slack_default
